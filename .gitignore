# Python cache/build
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.pytest_cache/
.coverage
htmlcov/

# Virtual environments
.venv/
.venv*/
.venv311/
venv/

# Local settings and secrets — catch ALL .env variants
.env
.env*
!.env.example

# IDE / OS
.vscode/
.DS_Store
Thumbs.db

# Runtime artifacts
data/hkjc_predictor.log
*.log

# Generated runtime state — already tracked files won't be deleted
data/predictions/cron_state.json
data/predictions/tick_notified.json
data/reports/maintenance_*.json
data/predictions/history.json
data/predictions/*.json

# Model binaries
*.pkl
*.joblib
*.h5

# Large generated datasets
data/**/*.csv
data/**/*.parquet
data/**/*.feather

# Optional local output folders
artifacts/
