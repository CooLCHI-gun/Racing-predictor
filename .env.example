# HKJC 賽馬預測系統 - 環境變數範例
# 複製此檔案為 .env 並填入實際數值

# ── Telegram Bot 設定 ──────────────────────────────────────────────────────
# 從 @BotFather 取得
TELEGRAM_TOKEN=your_telegram_bot_token_here
# 您的 Telegram Chat ID (可用 @userinfobot 查詢)
TELEGRAM_CHAT_ID=your_chat_id_here
# 訊息風格: pro (專業) | casual (口語)
MESSAGE_STYLE=pro

# ── Flask 設定 ─────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
# Railway 會自動注入 PORT，通常無需手動設定
# PORT=5000
FLASK_PORT=5000
FLASK_DEBUG=false

# ── 系統模式 ───────────────────────────────────────────────────────────────
# true = 使用模擬數據 (測試用), false = 使用真實 HKJC 數據
DEMO_MODE=false
REAL_DATA_ONLY=true
ALLOW_SYNTHETIC_TRAINING=false

# tick 去重狀態檔路徑（可指向 Railway Volume）
# 例: /data/tick_notified.json
TICK_SENT_STATE_FILE=data/predictions/tick_notified.json

# 單一 cron command 模式（Railway 受限時使用）
CRON_STATE_FILE=data/predictions/cron_state.json
CRON_MAINTENANCE_HOUR=21
CRON_MAINTENANCE_MINUTE=50
CRON_MAINTENANCE_WINDOW_MINS=10

# maintenance 通知與日常再訓練
MAINTENANCE_NOTIFY_ONLY_ON_NEW_SETTLED=true
MAINTENANCE_REPORT_DIR=data/reports
DAILY_RETRAIN_ENABLED=true
DAILY_RETRAIN_MIN_NEW_SETTLED=1
DAILY_RETRAIN_SYNTHETIC_RACES_BASE=600
DAILY_RETRAIN_SYNTHETIC_RACES_SCALE=8

# ── 代理設定 (可選) ────────────────────────────────────────────────────────
# HTTP_PROXY=http://your-proxy:port
# HTTPS_PROXY=http://your-proxy:port
