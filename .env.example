# HKJC 賽馬預測系統 - 環境變數範例
# 複製此檔案為 .env 並填入實際數值

# ── Telegram Bot 設定 ──────────────────────────────────────────────────────
# 從 @BotFather 取得
TELEGRAM_TOKEN=your_telegram_bot_token_here
# 您的 Telegram Chat ID (可用 @userinfobot 查詢)
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Flask 設定 ─────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-random-secret-key
# Railway 會自動注入 PORT，通常無需手動設定
# PORT=5000
FLASK_PORT=5000
FLASK_DEBUG=false

# ── 系統模式 ───────────────────────────────────────────────────────────────
# true = 使用模擬數據 (測試用), false = 使用真實 HKJC 數據
DEMO_MODE=false
REAL_DATA_ONLY=true
ALLOW_SYNTHETIC_TRAINING=false

# ── 代理設定 (可選) ────────────────────────────────────────────────────────
# HTTP_PROXY=http://your-proxy:port
# HTTPS_PROXY=http://your-proxy:port
